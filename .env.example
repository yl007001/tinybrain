# TinyBrain 环境变量配置（示例）
# 复制此文件为 .env 并填入你的真实 Key
# cp .env.example .env

# DeepSeek API Key（必须）
# 获取地址: https://platform.deepseek.com/api_keys
TINYBRAIN_LLM_KEY=sk-your-deepseek-api-key-here

# JWT 签名密钥（必须，用于 Token 签发和校验）
# 可用命令生成: openssl rand -hex 32
TINYBRAIN_JWT_SECRET=your-jwt-secret-here

# SerpAPI Key（可选，Agent 网络搜索工具）
# 获取地址: https://serpapi.com
TINYBRAIN_SEARCH_API_KEY=

# 向量存储目录
TINYBRAIN_VECTORSTORE_DIR=./data/vectorstore
